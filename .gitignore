# AI+NFT Studio — gitignore
# Covers: Node.js, Hardhat, Next.js, environment files, build artifacts

# ── Node ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
yarn.lock
pnpm-lock.yaml

# ── Environment ───────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Hardhat / Contracts ───────────────────────────────────────────
contracts/artifacts/
contracts/cache/
contracts/typechain-types/
contracts/coverage/
contracts/coverage.json
contracts/deployments.json

# ── Next.js / Frontend ────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/dist/
frontend/.vercel/
frontend/next-env.d.ts

# ── TypeScript ────────────────────────────────────────────────────
*.tsbuildinfo

# ── OS & Editor ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Test Coverage ────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ─────────────────────────────────────────────────────────
*.log
dist/
build/
