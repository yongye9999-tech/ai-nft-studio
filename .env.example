# ============================================
# AI+NFT Studio 环境变量配置
# Environment Variables Configuration
# ============================================

# --- AI 引擎 / AI Engine ---
# HuggingFace API密钥 (免费注册: https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# OpenAI API密钥 (注册: https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# --- IPFS 存储 / IPFS Storage ---
# Pinata API密钥 (免费注册: https://app.pinata.cloud/keys)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here

# --- 区块链 / Blockchain ---
# 钱包私钥 (⚠️ 切勿泄露! Never expose this!)
PRIVATE_KEY=your_wallet_private_key_here

# RPC节点URL (推荐 Alchemy/Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_key
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# 区块浏览器API (用于合约验证)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# --- 应用配置 / App Config ---
NEXT_PUBLIC_DEFAULT_CHAIN_ID=11155111
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=your_deployed_nft_contract_address
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ADDRESS=your_deployed_marketplace_address