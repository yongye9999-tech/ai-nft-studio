# ===========================================
# AI+NFT Studio — 环境变量模板
# Environment Variables Template
# ===========================================
# 复制本文件并重命名为 .env，然后填入真实值
# Copy this file, rename to .env, and fill in real values

# -------------------------------------------
# AI 引擎配置 / AI Engine Configuration
# -------------------------------------------

# HuggingFace API Token (免费，访问 https://huggingface.co/settings/tokens 获取)
# HuggingFace API Token (free, get at https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key (付费，访问 https://platform.openai.com/api-keys 获取)
# OpenAI API Key (paid, get at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 默认 AI 引擎 / Default AI Engine: "huggingface" or "openai"
NEXT_PUBLIC_DEFAULT_AI_ENGINE=huggingface

# -------------------------------------------
# IPFS / Pinata 配置
# IPFS / Pinata Configuration
# -------------------------------------------

# Pinata API Key (访问 https://app.pinata.cloud/keys 获取)
# Pinata API Key (get at https://app.pinata.cloud/keys)
PINATA_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Pinata API Secret
PINATA_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pinata JWT (推荐使用 JWT 方式)
# Pinata JWT (recommended)
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# IPFS 网关 / IPFS Gateway URL
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# -------------------------------------------
# 区块链配置 / Blockchain Configuration
# -------------------------------------------

# 私钥（部署合约用，不要泄露！）
# Private key for deploying contracts (NEVER share this!)
PRIVATE_KEY=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Sepolia 测试网 RPC URL (在 https://infura.io 或 https://alchemy.com 获取)
# Sepolia Testnet RPC URL (get from https://infura.io or https://alchemy.com)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-project-id

# Polygon Amoy 测试网 RPC URL
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# BNB 测试网 RPC URL
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Etherscan API Key (用于合约验证)
# Etherscan API Key (for contract verification)
ETHERSCAN_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -------------------------------------------
# 已部署的合约地址 / Deployed Contract Addresses
# (部署后填入 / Fill after deployment)
# -------------------------------------------

# Sepolia 测试网合约地址
NEXT_PUBLIC_AINFT_COLLECTION_SEPOLIA=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_NFT_MARKETPLACE_SEPOLIA=0x0000000000000000000000000000000000000000

# Polygon Amoy 测试网合约地址
NEXT_PUBLIC_AINFT_COLLECTION_AMOY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_NFT_MARKETPLACE_AMOY=0x0000000000000000000000000000000000000000
