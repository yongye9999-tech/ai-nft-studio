# AI+NFT Studio — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# 将此文件复制为 .env 并填入真实值，切勿将 .env 提交到版本控制。

# ── AI Generation APIs / AI 生成服务 ─────────────────────────────

# HuggingFace API Key — used for Stable Diffusion XL image generation
# 用于调用 HuggingFace Inference API 生成图片
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key — used for DALL-E 3 image generation
# 用于调用 OpenAI DALL-E 3 生成图片
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── IPFS / Pinata Storage / 去中心化存储 ─────────────────────────

# Pinata API Key (legacy)
# Pinata 旧版 API 密钥
PINATA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pinata API Secret (legacy)
# Pinata 旧版 API 密钥对应的 Secret
PINATA_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pinata JWT — preferred authentication method
# Pinata JWT 令牌（推荐使用此方式认证）
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx

# ── Blockchain / 区块链网络 ───────────────────────────────────────

# Deployer private key (without 0x prefix)
# 部署钱包的私钥（不带 0x 前缀），请使用专用测试钱包，切勿使用主钱包
PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sepolia testnet RPC URL (e.g. from Alchemy or Infura)
# Sepolia 测试网 RPC 地址（可从 Alchemy / Infura 获取）
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Polygon Amoy testnet RPC URL
# Polygon Amoy 测试网 RPC 地址
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-api-key

# BNB Smart Chain testnet RPC URL
# BNB 链测试网 RPC 地址
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# ── Block Explorer API Keys / 区块浏览器 API ──────────────────────

# Etherscan API Key — for contract verification on Ethereum / Sepolia
# Etherscan API 密钥，用于合约验证
ETHERSCAN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Polygonscan API Key — for contract verification on Polygon / Amoy
# Polygonscan API 密钥
POLYGONSCAN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# BscScan API Key — for contract verification on BNB Chain
# BscScan API 密钥
BSCSCAN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Frontend Public Variables / 前端公开变量 ─────────────────────
# These are exposed to the browser. NEXT_PUBLIC_ prefix is required.
# 以下变量会暴露给浏览器，请勿存入敏感信息。

# Deployed AINFTCollection contract address
# 已部署的 AINFTCollection 合约地址
NEXT_PUBLIC_AINFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Deployed NFTMarketplace contract address
# 已部署的 NFTMarketplace 合约地址
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Target chain ID (11155111 = Sepolia, 80002 = Polygon Amoy, 97 = BNB Testnet)
# 目标链 ID
NEXT_PUBLIC_CHAIN_ID=11155111
