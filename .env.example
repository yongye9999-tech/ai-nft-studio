# ============================================
# AI+NFT Studio 环境变量配置
# Environment Variables Configuration
# ============================================

# --- AI 引擎 / AI Engine ---
# HuggingFace API密钥 (免费注册: https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# OpenAI API密钥 (注册: https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Stability AI API密钥 (注册: https://platform.stability.ai/account/keys)
# 用于 Stable Diffusion 3.5 Large 高质量图像生成
STABILITY_API_KEY=your_stability_api_key_here

# Replicate API密钥 (注册: https://replicate.com/account/api-tokens)
# 用于 FLUX.1-dev 开源模型
REPLICATE_API_KEY=your_replicate_api_key_here

# Google Gemini / Imagen API密钥 (注册: https://aistudio.google.com/app/apikey)
# 用于 Imagen 3 照片级写实图像生成
GEMINI_API_KEY=your_gemini_api_key_here

# --- IPFS 存储 / IPFS Storage ---
# Pinata API密钥 (免费注册: https://app.pinata.cloud/keys)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here

# --- 区块链 / Blockchain ---
# 钱包私钥 (⚠️ 切勿泄露! Never expose this!)
PRIVATE_KEY=your_wallet_private_key_here

# RPC节点URL (推荐 Alchemy/Infura)
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_key
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# L2 网络 (Layer 2) — 低 Gas 主网
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org

# 区块浏览器API (用于合约验证)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here
ARBISCAN_API_KEY=your_arbiscan_api_key_here
BASESCAN_API_KEY=your_basescan_api_key_here

# --- 前端合约地址 / Frontend Contract Addresses ---
# 主网 / Mainnet (chainId: 1)
NEXT_PUBLIC_AINFT_COLLECTION_MAINNET=
NEXT_PUBLIC_NFT_MARKETPLACE_MAINNET=

# Polygon主网 / Polygon Mainnet (chainId: 137)
NEXT_PUBLIC_AINFT_COLLECTION_POLYGON=
NEXT_PUBLIC_NFT_MARKETPLACE_POLYGON=

# Sepolia测试网 / Sepolia Testnet (chainId: 11155111)
NEXT_PUBLIC_AINFT_COLLECTION_SEPOLIA=
NEXT_PUBLIC_NFT_MARKETPLACE_SEPOLIA=

# Polygon Amoy测试网 / Polygon Amoy Testnet (chainId: 80002)
NEXT_PUBLIC_AINFT_COLLECTION_AMOY=
NEXT_PUBLIC_NFT_MARKETPLACE_AMOY=

# BNB测试网 / BNB Testnet (chainId: 97)
NEXT_PUBLIC_AINFT_COLLECTION_BSC=
NEXT_PUBLIC_NFT_MARKETPLACE_BSC=

# Arbitrum One 主网 (chainId: 42161)
NEXT_PUBLIC_AINFT_COLLECTION_ARBITRUM=
NEXT_PUBLIC_NFT_MARKETPLACE_ARBITRUM=

# Base 主网 (chainId: 8453)
NEXT_PUBLIC_AINFT_COLLECTION_BASE=
NEXT_PUBLIC_NFT_MARKETPLACE_BASE=

# 本地开发 / Local Development (chainId: 31337)
NEXT_PUBLIC_AINFT_COLLECTION_LOCAL=
NEXT_PUBLIC_NFT_MARKETPLACE_LOCAL=

# --- 应用配置 / App Config ---
NEXT_PUBLIC_DEFAULT_CHAIN_ID=11155111